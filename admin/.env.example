# ─── Sui connection ───────────────────────────────────────────────────
VITE_SUI_RPC=https://fullnode.testnet.sui.io:443
VITE_LINEAGE_WAR_PACKAGE_ID=0x_YOUR_PACKAGE_ID
VITE_WAR_REGISTRY_ID=0x_YOUR_REGISTRY_ID

# ─── War config ──────────────────────────────────────────────────────
VITE_CURRENT_WAR_ID=1
VITE_CURRENT_ADMIN_CAP_ID=0x_YOUR_ADMIN_CAP_ID
VITE_CURRENT_ACTIVE_SYSTEM_IDS=30001,30002

# ─── Admin gate (client-side only — not real auth) ───────────────────
VITE_ADMIN_UNLOCK_PASSWORD=your-password-here
VITE_ADMIN_ALLOWLIST=0x_YOUR_WALLET_ADDRESS

# ─── World API ───────────────────────────────────────────────────────
VITE_WORLD_API_URL=https://world-api.evefrontier.com
