flowchart LR
    Chain["Sui testnet\nlineage_war Move package"]
    Admin["Admin browser\nReact + Sui wallet"]
    Scoreboard["Public scoreboard\nReact app"]
    ActivationApi["Activation API\nHono + PostgreSQL"]
    Prehype["Pre-war activation UI\nprehype/"]

    subgraph VerifierRuntime["Verifier runtime"]
        Verifier["Tick loop + artifact writer"]
        Ledger[("PostgreSQL\ncommitted_ticks_v2")]
        Http["Operator HTTP surfaces\n/status\n/notify\n/editorial-display"]
        PublicArtifacts["Public artifacts\n/verifier/latest.json\n/verifier/resolution.json\n/verifier/public-war-state.json\naudit/"]
        RuntimeStore["Internal runtime store\neditorial-display.json"]
    end

    Admin -->|"wallet-signed txs"| Chain
    Admin -->|"POST /notify\nGET/POST /editorial-display"| Http
    Http --> Verifier
    Verifier -->|"reads chain state"| Chain
    Verifier -->|"resolve_war tx"| Chain
    Verifier <--> Ledger
    Verifier --> PublicArtifacts
    Verifier --> RuntimeStore
    Scoreboard -->|"GET /verifier/latest.json\nGET audit artifacts"| PublicArtifacts
    Verifier -.->|"serves built / bundle"| Scoreboard
    Verifier -.->|"serves built /admin bundle"| Admin
    Prehype --> ActivationApi
