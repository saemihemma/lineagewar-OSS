# ─── Required ────────────────────────────────────────────────────────
LINEAGE_SUI_RPC=https://fullnode.testnet.sui.io:443
LINEAGE_PACKAGE_ID=0x_YOUR_PACKAGE_ID

# War ID override (optional -- auto-discovers latest war if not set)
# LINEAGE_WAR_ID=12

# Registry ID override (optional -- auto-discovered from WarCreatedEvent)
# LINEAGE_WAR_REGISTRY_ID=0x...

# ─── Auto-resolution ─────────────────────────────────────────────────
# Private key for the wallet that owns the WarAdminCap.
# The verifier auto-discovers the correct WarAdminCap by war ID.
# Required only for on-chain war resolution at war end.
# LINEAGE_ADMIN_PRIVATE_KEY=suiprivkey1...

# ─── Source mode ─────────────────────────────────────────────────────
# "seeded" | "chain" | "registry"
LINEAGE_SOURCE=seeded
LINEAGE_SCENARIO=two-tribe-two-system

# ─── Registry paths (for registry source mode) ──────────────────────
LINEAGE_ASSEMBLY_REGISTRY_PATH=registry/live-assemblies.example.json
LINEAGE_OWNER_TRIBE_REGISTRY_PATH=registry/owner-tribes.example.json
LINEAGE_LOCATION_MAPPING_PATH=registry/location-hashes.example.json
LINEAGE_ASSEMBLY_SYSTEM_MAPPING_PATH=registry/assembly-system-mapping.example.json
LINEAGE_SYSTEM_NAMES_PATH=registry/system-names.example.json
LINEAGE_SYSTEM_DISPLAY_CONFIG_PATH=registry/system-display.example.json

# ─── Snapshot commit (for submit:commit) ─────────────────────────────
# LINEAGE_SUI_PRIVATE_KEY=suiprivkey1...
# LINEAGE_COMMIT_INPUT=path/to/latest.json

# ─── World / Location ─────────────────────────────────────────────────
# LINEAGE_WORLD_PACKAGE_ID is used to auto-derive the location event type
# (LINEAGE_WORLD_PACKAGE_ID::location::LocationRevealedEvent).
# Only set LINEAGE_LOCATION_EVENT_TYPE if the module path differs.
LINEAGE_WORLD_PACKAGE_ID=0x28b497559d65ab320d9da4613bf2498d5946b2c0ae3597ccfda3072ce127448c
# LINEAGE_LOCATION_QUERY_MODE=auto
# LINEAGE_SUI_GRAPHQL_URL=
# LINEAGE_LOCATION_EVENT_TYPE=
# LINEAGE_WORLD_API_BASE=
# LINEAGE_WORLD_API_AUTHORIZATION=Bearer <token>

# ─── Phase overrides ────────────────────────────────────────────────
# LINEAGE_PHASE_LABEL=
# LINEAGE_PHASE_END_MS=
# LINEAGE_PHASE_STATUS_WITHHELD=1
# LINEAGE_WAR_END_MS=

# ─── Output ──────────────────────────────────────────────────────────
# LINEAGE_OUTPUT_PATH=
# LINEAGE_VERIFIER_VERSION=
