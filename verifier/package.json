{
  "name": "lineage-war-verifier",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Live verifier and public artifact server for Lineage War.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/live-chain-loop.ts",
    "start:once": "tsx src/live-chain-loop.ts --once",
    "inspect:deploy": "tsx src/inspect-deploy.ts",
    "inspect:war": "tsx src/inspect-war.ts",
    "inspect:tick-path": "tsx src/inspect-tick-path.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3"
  }
}
