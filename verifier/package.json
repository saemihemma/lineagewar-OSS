{
  "name": "lineage-war-verifier",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Tracer-bullet verifier for the Lineage War scoring engine.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "demo": "tsx src/main.ts",
    "demo:json": "tsx src/main.ts --json",
    "demo:seeded": "tsx src/main.ts --source=seeded --scenario=two-tribe-two-system",
    "demo:chain": "tsx src/main.ts --source=chain --scenario=two-tribe-two-system",
    "demo:registry": "tsx src/main.ts --source=registry --scenario=two-tribe-two-system",
    "emit:score": "tsx src/main.ts --source=seeded --scenario=live-war --output=../frontend/score/public/verifier/latest.json",
    "emit:live": "tsx src/live-simulator.ts --once --scenario=live-war --initial-ticks=12 --max-history=90 --interval-seconds=15",
    "watch:live": "tsx src/live-simulator.ts --scenario=live-war --initial-ticks=12 --max-history=90 --interval-seconds=15",
    "import:spawned-world": "tsx src/import-spawned-world.ts",
    "collect:location-events": "tsx src/fetch-location-events.ts",
    "setup:testnet-war": "tsx src/setup-testnet-war.ts",
    "prepare:commit": "tsx src/prepare-commit.ts",
    "submit:commit": "tsx src/submit-commit.ts",
    "verify:audit": "tsx src/verify-audit.ts",
    "start": "tsx src/live-chain-loop.ts",
    "start:once": "tsx src/live-chain-loop.ts --once",
    "inspect:deploy": "tsx src/inspect-deploy.ts",
    "inspect:war": "tsx src/inspect-war.ts",
    "inspect:tick-path": "tsx src/inspect-tick-path.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3"
  }
}
